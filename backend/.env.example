# Darpan Labs Backend Configuration

# Application
APP_NAME="Darpan Labs Digital Twin"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development

# API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:darpan@localhost:5432/darpan
DATABASE_ECHO=false

# Redis
